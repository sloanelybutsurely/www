---
const title = Astro.props.title ?? Astro.props.frontmatter?.title;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head><body>
    <slot />
  </body>
</html>
